{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "paths",
  "main": "dist/server/server.js",
  "compatibility_date": "2024-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS"
  },
  "build": {
    "command": "npm run build"
  }
}
